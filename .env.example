# claude-code-bridge — environment variable reference
# Copy this file to ~/.env (or wherever your shell sources env vars from) and fill in real values.
# NEVER commit a filled-in version of this file.

# --- Provider API keys ---
# At least one is required, matching the provider shell function you plan to use.

# DeepSeek — used by `claude-deepseek`. Get from https://platform.deepseek.com
DEEPSEEK_API_KEY=

# OpenAI — used by `claude-openai`. Get from https://platform.openai.com/account/api-keys
OPENAI_API_KEY=

# Google Gemini — used by `claude-gemini`. Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Bridge runtime config ---

# Port the LiteLLM proxy listens on locally. Override if port 4000 is in use.
# Every shell function uses this port for both its health check and ANTHROPIC_BASE_URL.
CLAUDE_BRIDGE_PROXY_PORT=4000
